-- 1. Таблица самих промокодов
CREATE TABLE IF NOT EXISTS promo_codes (
    id SERIAL PRIMARY KEY,
    partner_id VARCHAR(50) NOT NULL,
    code VARCHAR(50) NOT NULL,
    reward NUMERIC(15, 2) NOT NULL,
    max_uses INT DEFAULT 1,
    current_uses INT DEFAULT 0, -- Счетчик реальных активаций
    is_active INT DEFAULT 1,
    timestamp TIMESTAMP DEFAULT NOW(),
    expires_at TIMESTAMP DEFAULT NULL,
    UNIQUE(partner_id, code) -- Защита от дублей кода внутри одного партнера
);

-- 2. Таблица логов активаций (для аналитики админки и защиты от повторных использований)
CREATE TABLE IF NOT EXISTS promo_activations (
    id SERIAL PRIMARY KEY,
    partner_id VARCHAR(50) NOT NULL,
    username VARCHAR(50) NOT NULL,
    code VARCHAR(50) NOT NULL,
    timestamp TIMESTAMP DEFAULT NOW(),
    UNIQUE(partner_id, username, code) -- Игрок может активировать конкретный код строго 1 раз
);

-- Индексы для мгновенной проверки кодов
CREATE INDEX IF NOT EXISTS idx_promo_search ON promo_codes(partner_id, code);

-- 1. Таблица шаблонов квестов (создает админ)
CREATE TABLE IF NOT EXISTS b2b_quests (
    id SERIAL PRIMARY KEY,
    partner_id VARCHAR(50) NOT NULL,
    quest_type VARCHAR(30) NOT NULL,    -- 'GAMES_COUNT', 'TURNOVER_BET', 'WIN_COUNT'
    target_value NUMERIC(15, 2) NOT NULL, -- Цель (например: 30 игр или 500 коинов оборота)
    reward_amount NUMERIC(15, 2) NOT NULL, -- Награда за выполнение
    description TEXT NOT NULL,
    is_active INT DEFAULT 1,
    UNIQUE(partner_id, quest_type) -- Один активный тип квеста на партнера в день
);

-- 2. Таблица прогресса игроков (чтобы очистить players от поля daily_quests)
CREATE TABLE IF NOT EXISTS player_quest_progress (
    partner_id VARCHAR(50) NOT NULL,
    username VARCHAR(50) NOT NULL,
    quest_id INT NOT NULL REFERENCES b2b_quests(id) ON DELETE CASCADE,
    current_value NUMERIC(15, 2) DEFAULT 0.00, -- Текущий прогресс игрока
    is_claimed BOOLEAN DEFAULT false,          -- Забрал ли награду
    updated_at TIMESTAMP DEFAULT NOW(),
    PRIMARY KEY (partner_id, username, quest_id)
);

-- 1. Шаблоны и параметры текущих/будущих турниров
CREATE TABLE IF NOT EXISTS b2b_tournaments (
    id SERIAL PRIMARY KEY,
    partner_id VARCHAR(50) NOT NULL,
    title VARCHAR(100) NOT NULL,
    prize_pool NUMERIC(15, 2) NOT NULL,
    min_bet_to_earn NUMERIC(15, 2) DEFAULT 0.00, -- Минимальная ставка для начисления очков
    start_at TIMESTAMP NOT NULL,
    end_at TIMESTAMP NOT NULL,
    is_active INT DEFAULT 1,
    UNIQUE(partner_id, is_active) -- Только 1 активный турнир у партнера одновременно
);

-- 2. Изолированная таблица очков участников (Лидерборд)
CREATE TABLE IF NOT EXISTS tournament_leaderboard (
    tournament_id INT REFERENCES b2b_tournaments(id) ON DELETE CASCADE,
    partner_id VARCHAR(50) NOT NULL,
    username VARCHAR(50) NOT NULL,
    points INT DEFAULT 0,
    updated_at TIMESTAMP DEFAULT NOW(),
    PRIMARY KEY (tournament_id, username)
);

-- 3. История завершенных чемпионатов и их победителей
CREATE TABLE IF NOT EXISTS tournament_history (
    id SERIAL PRIMARY KEY,
    tournament_id INT NOT NULL,
    partner_id VARCHAR(50) NOT NULL,
    title VARCHAR(100) NOT NULL,
    winner_username VARCHAR(50) NOT NULL,
    place INT NOT NULL, -- 1, 2, 3 место
    points_earned INT NOT NULL,
    prize_paid NUMERIC(15, 2) NOT NULL,
    ended_at TIMESTAMP DEFAULT NOW()
);

-- Индекс для мгновенной сборки лидерборда ТОП-10
CREATE INDEX IF NOT EXISTS idx_tournament_leaderboard_score
ON tournament_leaderboard (tournament_id, points DESC);


-- 1. Таблица сайтов (Брендов/Доменов)
CREATE TABLE IF NOT EXISTS b2b_websites (
    id SERIAL PRIMARY KEY,
    partner_id VARCHAR(50) NOT NULL,
    domain_name VARCHAR(100) NOT NULL, -- например, 'mtwcasino.com'
    title VARCHAR(100) NOT NULL,       -- Понятное название для админки
    is_active INT DEFAULT 1,
    timestamp TIMESTAMP DEFAULT NOW(),
    UNIQUE(partner_id, domain_name)    -- Защита от дублей доменов у одного партнера
);

-- 2. Таблица баннеров
CREATE TABLE IF NOT EXISTS b2b_banners (
    id SERIAL PRIMARY KEY,
    partner_id VARCHAR(50) NOT NULL,
    website_id INT NOT NULL REFERENCES b2b_websites(id) ON DELETE CASCADE,
    banner_type VARCHAR(20) NOT NULL,  -- 'home', 'casino', 'sport'
    image_url TEXT NOT NULL,           -- Ссылка на картинку
    click_url TEXT DEFAULT '',         -- Куда ведет баннер при клике (кнопка)
    sort_order INT DEFAULT 0,          -- Очередность вывода (сортировка)
    is_active INT DEFAULT 1,
    settings JSONB DEFAULT '{}'::jsonb,
    meta     JSONB DEFAULT '{}'::jsonb,
    styles   JSONB DEFAULT '{}'::jsonb,
    timestamp TIMESTAMP DEFAULT NOW()
);

-- Индексы для мгновенной сборки слайдеров на фронтенде игроков
CREATE INDEX IF NOT EXISTS idx_banners_render ON b2b_banners (website_id, banner_type, is_active, sort_order ASC);

CREATE TABLE IF NOT EXISTS b2b_payment_gateways (
    id SERIAL PRIMARY KEY,
    partner_id VARCHAR(50) NOT NULL,
    website_id INT NOT NULL REFERENCES b2b_websites(id) ON DELETE CASCADE,
    gateway_name VARCHAR(50) NOT NULL, -- 'cryptomus', 'aaio', 'payok'
    merchant_id VARCHAR(100) NOT NULL,
    secret_key TEXT NOT NULL,
    is_active INT DEFAULT 1,
    timestamp TIMESTAMP DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS deposit_orders (
    id SERIAL PRIMARY KEY,
    partner_id VARCHAR(50) NOT NULL,
    username VARCHAR(50) NOT NULL,
    order_uuid VARCHAR(100) NOT NULL UNIQUE, -- Уникальный ID платежа для платежки
    gateway VARCHAR(30) NOT NULL,            -- 'cryptomus' или 'aaio'
    amount NUMERIC(15, 2) NOT NULL,
    status VARCHAR(20) DEFAULT 'PENDING',    -- 'PENDING', 'SUCCESS', 'FAILED'
    timestamp TIMESTAMP DEFAULT NOW()
);

-- Индекс для мгновенного поиска заказа по вебхуку
CREATE INDEX IF NOT EXISTS idx_deposit_orders_uuid ON deposit_orders(order_uuid);

CREATE TABLE IF NOT EXISTS withdraw_requests (
    id SERIAL PRIMARY KEY,
    partner_id VARCHAR(50) NOT NULL,
    username VARCHAR(50) NOT NULL,
    amount NUMERIC(15, 2) NOT NULL,
    gateway VARCHAR(30) NOT NULL,            -- 'cryptomus', 'aaio', 'payeer', 'pix'
    wallet_details TEXT NOT NULL,            -- Номер карты или криптокошелька игрока
    status VARCHAR(20) DEFAULT 'PENDING',    -- 'PENDING', 'APPROVED', 'REJECTED'
    timestamp TIMESTAMP DEFAULT NOW()
);

-- Индекс для админки, чтобы быстро выводить новые заявки
CREATE INDEX IF NOT EXISTS idx_withdraw_pending ON withdraw_requests(partner_id, status);

CREATE TABLE IF NOT EXISTS b2b_welcome_bonuses (
    id SERIAL PRIMARY KEY,
    partner_id VARCHAR(50) NOT NULL,
    website_id INT NOT NULL REFERENCES b2b_websites(id) ON DELETE CASCADE,
    bonus_percent INT DEFAULT 100,       -- Процент бонуса (например, 100%)
    wager_multiplier INT DEFAULT 30,     -- Вейджер (например, x30)
    min_deposit_amount NUMERIC(15, 2) DEFAULT 100.00, -- Минимальный деп для активации
    max_bonus_amount NUMERIC(15, 2) DEFAULT 5000.00,  -- Максимальная сумма подарка
    is_active INT DEFAULT 1,
    UNIQUE(website_id) -- Один велкам-бонус на один сайт
);

-- 3. Таблица Антифрод-инцидентов (Подозрительные действия)
CREATE TABLE IF NOT EXISTS antifraud_alerts (
    id SERIAL PRIMARY KEY,
    partner_id VARCHAR(50) NOT NULL,
    username VARCHAR(50) NOT NULL,
    alert_type VARCHAR(50) NOT NULL,     -- 'SPEED_WITHDRAW', 'ZERO_TURNOVER', 'HIGH_WINRATE'
    risk_score INT NOT NULL,             -- Оценка риска от 1 до 100
    description TEXT NOT NULL,
    status VARCHAR(20) DEFAULT 'NEW',    -- 'NEW', 'REVIEWED', 'DISMISSED'
    timestamp TIMESTAMP DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_antifraud_status ON antifraud_alerts(partner_id, status);