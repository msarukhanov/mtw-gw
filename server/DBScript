-- 1. Таблица игроков
CREATE TABLE IF NOT EXISTS players (
    id SERIAL PRIMARY KEY,
    username VARCHAR(50) NOT NULL,
    partner_id VARCHAR(50) NOT NULL,
    balance NUMERIC(15, 2) DEFAULT 0.00,
    xp INT DEFAULT 0,
    level INT DEFAULT 1,
    invited_by VARCHAR(50),
    daily_quests JSONB DEFAULT '{"gamesPlayed": 0, "claimed": false}'::jsonb,
    used_promos JSONB DEFAULT '{}'::jsonb,
    history JSONB DEFAULT '[]'::jsonb,
    tournament_points INT DEFAULT 0,
    is_banned BOOLEAN DEFAULT false;
    casino_min_limit NUMERIC(15, 2) DEFAULT NULL,
    casino_max_limit NUMERIC(15, 2) DEFAULT NULL,
    sport_min_limit NUMERIC(15, 2) DEFAULT NULL,
    sport_max_limit NUMERIC(15, 2) DEFAULT NULL,
    password_hash TEXT DEFAULT NULL,
    bonus_balance NUMERIC(15, 2) DEFAULT 0.00,
    wager_total NUMERIC(15, 2) DEFAULT 0.00,
    wager_left NUMERIC(15, 2) DEFAULT 0.00,
    total_deposited_amount NUMERIC(15, 2) DEFAULT 0.00,
    UNIQUE(username, partner_id)
);

CREATE INDEX IF NOT EXISTS idx_players_partner_search ON players (partner_id, username);

-- 2. Логи транзакций
CREATE TABLE IF NOT EXISTS accounting_logs (
    id SERIAL PRIMARY KEY,
    partner_id VARCHAR(50) NOT NULL,
    username VARCHAR(50) NOT NULL,
    type VARCHAR(20) NOT NULL,
    amount NUMERIC(15, 2) NOT NULL,
    game VARCHAR(100) NOT NULL,
    timestamp TIMESTAMP DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_accounting_logs_report
ON accounting_logs (partner_id, type, timestamp DESC);

-- 3. Спортивные ставки
CREATE TABLE IF NOT EXISTS sports_bets (
    id SERIAL PRIMARY KEY,
    username VARCHAR(50) NOT NULL,
    partner_id VARCHAR(50) NOT NULL,
    type VARCHAR(20) NOT NULL,
    items JSONB NOT NULL,
    total_odds NUMERIC(8, 2) NOT NULL,
    stake NUMERIC(15, 2) NOT NULL,
    status VARCHAR(20) NOT NULL,
    prize NUMERIC(15, 2) DEFAULT 0.00,
    timestamp TIMESTAMP DEFAULT NOW()
);

-- 1. Таблица для ставок в казино (дефолт)
CREATE TABLE IF NOT EXISTS casino_bets (
    id SERIAL PRIMARY KEY,
    username VARCHAR(50) NOT NULL,
    partner_id VARCHAR(50) NOT NULL,
    game_id VARCHAR(50) NOT NULL,
    provider VARCHAR(50) NOT NULL,
    session_id VARCHAR(100),
    stake NUMERIC(15, 2) NOT NULL,          -- Сумма ставки
    prize NUMERIC(15, 2) DEFAULT 0.00,      -- Выигрыш (0 если проигрыш)
    status VARCHAR(20) NOT NULL,            -- 'WIN', 'LOSE', 'REFUND'
    timestamp TIMESTAMP DEFAULT NOW()
);

-- 2. Единая таблица истории для вывода игроку (включает системные события и линки на ставки)
CREATE TABLE IF NOT EXISTS player_history (
    id SERIAL PRIMARY KEY,
    username VARCHAR(50) NOT NULL,
    partner_id VARCHAR(50) NOT NULL,
    category VARCHAR(20) NOT NULL,          -- 'casino', 'sport', 'system'
    action_type VARCHAR(50) NOT NULL,       -- 'bet', 'tournament_end', 'level_up', 'quest'
    description TEXT NOT NULL,              -- Текстовое описание для фронтенда
    amount_change NUMERIC(15, 2) DEFAULT 0, -- Изменение баланса (например, +100 или -10)
    reference_id INT,                       -- ID из таблицы sports_bets или casino_bets (если применимо)
    timestamp TIMESTAMP DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_casino_bets_user_partner ON casino_bets(partner_id, username);
CREATE INDEX IF NOT EXISTS idx_sports_bets_user_partner ON sports_bets(partner_id, username);
CREATE INDEX IF NOT EXISTS idx_player_history_user_partner ON player_history(partner_id, username, timestamp DESC);

CREATE INDEX IF NOT EXISTS idx_casino_bets_timestamp
ON casino_bets (partner_id, timestamp DESC);

-- Индекс для быстрого поиска по датам в спортивных ставках
CREATE INDEX IF NOT EXISTS idx_sports_bets_timestamp
ON sports_bets (partner_id, timestamp DESC);

-- Индекс для истории, если админы или игроки захотят фильтровать логи по датам
CREATE INDEX IF NOT EXISTS idx_player_history_timestamp
ON player_history (partner_id, timestamp DESC);

-- 4. Матчи виртуального футбола
CREATE TABLE IF NOT EXISTS matches (
    id SERIAL PRIMARY KEY,
    match_id VARCHAR(100) UNIQUE NOT NULL, -- Строковый ID (например, fb_ucl_1717768800)
    sport VARCHAR(50) NOT NULL,
    league VARCHAR(100) NOT NULL,
    teams JSONB NOT NULL,                 -- Имена и сырые данные команд
    status VARCHAR(20) NOT NULL,           -- PREMATCH, LIVE, FINISHED
    minute INT DEFAULT 0,
    score_home INT DEFAULT 0,
    score_away INT DEFAULT 0,
    markets JSONB NOT NULL,               -- Сгенерированные коэффициенты рынков
    ball_zone INT DEFAULT 0               -- Зона мяча в лайве
);

-- 5. История лотереи
CREATE TABLE IF NOT EXISTS lottery_history (
    id SERIAL PRIMARY KEY,
    draw_data JSONB NOT NULL
);

-- 6. Бэкенд-конфигурации партнеров
CREATE TABLE IF NOT EXISTS b2b_configs (
    id VARCHAR(50) PRIMARY KEY,
    config_data JSONB NOT NULL
);

-- Удаляем старые таблицы, чтобы пересоздать их с правильными типами данных
DROP TABLE IF EXISTS partner_collections CASCADE;
DROP TABLE IF EXISTS partner_games CASCADE;
DROP TABLE IF EXISTS partner_aggregators CASCADE;
DROP TABLE IF EXISTS game_sessions CASCADE;
DROP TABLE IF EXISTS games CASCADE;

-- 1. Таблица каталога игр
CREATE TABLE games (
    id SERIAL PRIMARY KEY,
    slug VARCHAR(100) UNIQUE NOT NULL,
    name VARCHAR(150) NOT NULL,
    aggregator VARCHAR(100) DEFAULT 'INTERNAL',
    provider VARCHAR(100) NOT NULL,
    has_demo BOOLEAN DEFAULT TRUE,
    is_multiplayer BOOLEAN DEFAULT FALSE,
    description TEXT,
    image VARCHAR(255),
    base VARCHAR(50),
    theme VARCHAR(100),
    url VARCHAR(255) NOT NULL,
    is_active BOOLEAN DEFAULT TRUE,
    categories JSONB DEFAULT '[]'::jsonb, -- Категории хранятся в JSONB
    rtp_settings JSONB DEFAULT '{}'::jsonb,
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW()
);

-- 2. Настройки провайдеров для партнеров
CREATE TABLE partner_aggregators (
    id SERIAL PRIMARY KEY,
    partner_id VARCHAR(50) NOT NULL,
    aggregator VARCHAR(100) NOT NULL,
    is_active BOOLEAN DEFAULT TRUE,
    updated_at TIMESTAMP DEFAULT NOW(),
    UNIQUE(partner_id, aggregator)
);

-- 3. Настройки конкретных игр для партнеров
CREATE TABLE partner_games (
    id SERIAL PRIMARY KEY,
    partner_id VARCHAR(50) NOT NULL,
    game_id INT REFERENCES games(id) ON DELETE CASCADE, -- При удалении игры чистим настройки
    is_active BOOLEAN DEFAULT TRUE,
    custom_name VARCHAR(150),
    custom_slug VARCHAR(100),
    custom_theme VARCHAR(100),
    custom_rtp NUMERIC(5,2),
    updated_at TIMESTAMP DEFAULT NOW(),
    UNIQUE(partner_id, game_id)
);

-- 4. ИСПРАВЛЕНО: Таблица коллекций игр партнеров (game_ids теперь строго INT[])
CREATE TABLE partner_collections (
    id SERIAL PRIMARY KEY,
    partner_id VARCHAR(50) NOT NULL,
    name VARCHAR(100) NOT NULL,
    slug VARCHAR(100) NOT NULL,
    game_ids INT[] DEFAULT '{}'::int[], -- Нативный целочисленный массив Postgres!
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW(),
    UNIQUE(partner_id, slug)
);

-- 5. Игровые сессии запуска (iFrame)
CREATE TABLE game_sessions (
    id SERIAL PRIMARY KEY,
    token VARCHAR(100) UNIQUE NOT NULL,
    partner_id VARCHAR(50) NOT NULL,
    username VARCHAR(50),
    game_slug VARCHAR(100) NOT NULL,
    is_demo BOOLEAN DEFAULT FALSE,
    theme VARCHAR(50) DEFAULT 'default',
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT NOW(),
    expired_at TIMESTAMP NOT NULL
);

-- Индексы для максимальной скорости запросов
CREATE INDEX idx_games_slug ON games(slug);
CREATE INDEX idx_partner_games_route ON partner_games(partner_id, game_id);
CREATE INDEX idx_partner_coll_route ON partner_collections(partner_id, slug);
CREATE INDEX idx_game_sessions_token ON game_sessions(token);



